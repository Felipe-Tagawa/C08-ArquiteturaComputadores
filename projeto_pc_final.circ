    <comp lib="7" loc="(420,230)" name="MIPSProgramROM">
      <a name="contents">start:
    addiu $8, $0, 0      # ponteiro leitura, comeÃ§a no inÃ­cio do vetor
    addiu $9, $0, 32     # ponteiro leitura invertida, comeÃ§a no fim do vetor  
    addiu $10, $0, 36    # ponteiro escrita, comeÃ§a apÃ³s o vetor original
    addiu $11, $0, 1     # constante 1
    addiu $12, $0, 4     # constante 4
    addiu $13, $0, 9     # contador

loop:
    beq $13, $0, fim
    lw $14, 0($9)        # lÃª do fim do vetor original
    sw $14, 0($10)       # escreve na regiÃ£o invertida
    subu $9, $9, $12     # ponteiro leitura recua 4
    addu $10, $10, $12   # ponteiro escrita avanÃ§a 4
    subu $13, $13, $11   # contador--
    j loop

fim:
    j fim
</a>
    </comp>
